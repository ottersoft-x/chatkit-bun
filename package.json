{
  "name": "chatkit-bun",
  "version": "0.0.3",
  "description": "Bun-native server helpers for ChatKit-style thread APIs.",
  "license": "Apache-2.0",
  "module": "./src/index.ts",
  "types": "./types/index.d.ts",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ottersoft-x/chatkit-bun"
  },
  "homepage": "https://github.com/ottersoft-x/chatkit-bun#readme",
  "bugs": {
    "url": "https://github.com/ottersoft-x/chatkit-bun/issues"
  },
  "keywords": [
    "bun",
    "chatkit",
    "openai",
    "agents",
    "sse"
  ],
  "files": [
    "NOTICE",
    "src",
    "types"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.ts"
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/nunjucks": "^3.2.6",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "dependencies": {
    "@openai/agents": "^0.11.5",
    "nunjucks": "^3.2.4",
    "zod": "^4.4.3"
  },
  "scripts": {
    "test": "bun test",
    "build:types": "bunx tsc -p tsconfig.types.json",
    "typecheck": "bunx tsc --noEmit",
    "verify": "bun run typecheck && bun test",
    "verify:parity": "bun run verify && bun scripts/verify-parity.ts"
  }
}
